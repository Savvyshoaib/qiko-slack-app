# --- Production (Render): OAuth multi-workspace — do NOT set SLACK_BOT_TOKEN ---
SLACK_SIGNING_SECRET=your_signing_secret
SLACK_CLIENT_ID=your_client_id
SLACK_CLIENT_SECRET=your_client_secret
SLACK_STATE_SECRET=use-a-long-random-string-here

# Render sets RENDER_EXTERNAL_URL automatically; override if needed:
# SLACK_APP_URL=https://qiko-slack-app.onrender.com

# Render Postgres (Blueprint links DATABASE_URL)
# DATABASE_URL=postgres://...

PORT=3001
QIKO_API_BASE_URL=https://stage-backend.qiko.ai/api/avatar

# --- Local dev only (single workspace) ---
# SLACK_BOT_TOKEN=xoxb-your-bot-token
# SLACK_APP_TOKEN=xapp-your-app-token
